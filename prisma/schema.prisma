generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Runtime config overrides edited via /admin UI.
/// Read cascade in SettingsService: DB row -> .env -> schema default.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
