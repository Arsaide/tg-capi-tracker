{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2021",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "declaration": false,
        "removeComments": true,
        "outDir": "./dist",
        "baseUrl": "./",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strictNullChecks": false,
        "forceConsistentCasingInFileNames": true
    }
}
